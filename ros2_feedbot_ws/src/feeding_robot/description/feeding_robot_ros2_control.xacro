<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="use_sim" default="true"/>

  <ros2_control name="FeedingRobotSystem" type="system">
    <hardware>
      <xacro:if value="$(arg use_sim)">
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:unless value="$(arg use_sim)">
        <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>
        <param name="usb_port">/dev/ttyACM0</param>
        <param name="baud_rate">57600</param>
        <param name="number_of_joints">4</param>
        <param name="joint_ids">11,12,13,14</param>
        <param name="disable_torque_at_init">true</param>
      </xacro:unless>
    </hardware>

    <!-- Base Y Joint - Yaw rotation (Dynamixel ID 11) -->
    <joint name="base_y_joint">
      <param name="id">11</param>
      <command_interface name="position">
        <param name="min">${-175.0 * pi / 180.0}</param>
        <param name="max">${175.0 * pi / 180.0}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Lower Z Joint - Shoulder pitch (Dynamixel ID 12) -->
    <joint name="lower_z_joint">
      <param name="id">12</param>
      <command_interface name="position">
        <param name="min">${-90.0 * pi / 180.0}</param>
        <param name="max">${90.0 * pi / 180.0}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Upper Z Joint - Elbow pitch (Dynamixel ID 13) -->
    <joint name="upper_z_joint">
      <param name="id">13</param>
      <command_interface name="position">
        <param name="min">${-120.0 * pi / 180.0}</param>
        <param name="max">${75.0 * pi / 180.0}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Feeder Joint - Wrist pitch (Dynamixel ID 14) -->
    <joint name="feeder_joint">
      <param name="id">14</param>
      <command_interface name="position">
        <param name="min">${-90.0 * pi / 180.0}</param>
        <param name="max">${115.0 * pi / 180.0}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

</robot>
